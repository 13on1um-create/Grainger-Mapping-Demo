{
  "$comment": "Field mapping for Grainger's Collection of Music by Other Composers -> Axiell EMu. Machine-readable form of the 'Field Mapping' sheet. confidence: 'Standard' = common EMu default column; 'Verify' = concept maps cleanly but exact column is config-dependent (confirm against the museum's data dictionary via the EMu '?' field-help tool); 'Concept' = a relationship/structure rather than a single field. emu_column values marked Verify MUST be confirmed before a production load.",
  "target_system": "Axiell EMu",
  "primary_module": "ecatalogue",
  "linked_modules": ["eparties", "emultimedia", "eaccession"],
  "fields": [
    {
      "id": 1,
      "element": "Grainger classification / shelf number",
      "isbd_area": "Local identifier",
      "example": "MG C1/BAC-65-2",
      "module": "ecatalogue",
      "tab_group": "Identification / Numbers",
      "emu_column": ["<primary object/registration number field>", "NumOtherKind_tab", "NumOtherNumber_tab"],
      "repeatable": "maybe",
      "links_to": null,
      "transform_notes": "Record's human-readable ID. Encodes hierarchy: C1=collection, BAC=author cutter (Bach), -65=work, -2=manifestation, :1=part. Store as primary object number AND as an Other Number with NumOtherKind_tab='Grainger classification'. Parse components to drive parent/child/sibling links.",
      "confidence": "Verify"
    },
    {
      "id": 2,
      "element": "Composer / author heading",
      "isbd_area": "Name authority",
      "example": "BACKER-LUNDE, Johan 1874-",
      "module": "eparties",
      "tab_group": "linked from Production",
      "emu_column": ["creator party link", "role"],
      "repeatable": "yes",
      "links_to": "eparties",
      "transform_notes": "Heading repeats across entries -> deduplicate to one Party record (Person). Trailing dates = birth/death. Emit as a creators[] entry with role='Composer'.",
      "confidence": "Standard"
    },
    {
      "id": 3,
      "element": "Uniform (standardized) title",
      "isbd_area": "Uniform title",
      "example": "[Toccatas, organ, S.565, D minor; arr.]",
      "module": "ecatalogue",
      "tab_group": "Identification / Titles",
      "emu_column": ["TitObjectTitle"],
      "repeatable": "maybe",
      "links_to": null,
      "transform_notes": "Square-bracketed. Encodes work-type, medium (organ), thematic-cat no. (S.565), key (D minor) and an 'arr.' flag. Also emit parsed thematic no. (-> field 4), key, and arr.=true.",
      "confidence": "Verify"
    },
    {
      "id": 4,
      "element": "Thematic-catalogue number",
      "isbd_area": null,
      "example": "S.565 / S.1068",
      "module": "ecatalogue",
      "tab_group": "Identification / Other Numbers",
      "emu_column": ["NumOtherKind_tab", "NumOtherNumber_tab"],
      "repeatable": "yes",
      "links_to": null,
      "transform_notes": "Extract from the uniform title. 'S.' = Schmieder = BWV. NumOtherKind_tab='Thematic catalogue (BWV)'.",
      "confidence": "Standard"
    },
    {
      "id": 5,
      "element": "Title proper",
      "isbd_area": "Area 1 (title)",
      "example": "Toccata and fugue in D minor for organ (pedal and manual)",
      "module": "ecatalogue",
      "tab_group": "Identification / Titles",
      "emu_column": ["TitMainTitle"],
      "repeatable": "no",
      "links_to": null,
      "transform_notes": "Text before the first ' / '.",
      "confidence": "Standard"
    },
    {
      "id": 6,
      "element": "Statement of responsibility",
      "isbd_area": "Area 1 (after /)",
      "example": "/ J.S. Bach ; free piano-arrangement by Carl Tausig ; edited and fingered by Paolo Gallico",
      "module": "ecatalogue -> eparties",
      "tab_group": "Production / Creator",
      "emu_column": ["creator party link", "role"],
      "repeatable": "yes",
      "links_to": "eparties",
      "transform_notes": "Split on ';'. Map role phrases to controlled Role vocab (Composer/Arranger/Editor/Fingering). 'edited and fingered by' -> two roles for the same party. One creators[] entry per agent+role.",
      "confidence": "Standard"
    },
    {
      "id": 7,
      "element": "Edition statement",
      "isbd_area": "Area 2 (edition)",
      "example": "Neue durchgesehene Ausgabe; The Associated Board edition",
      "module": "ecatalogue",
      "tab_group": "Identification / Edition",
      "emu_column": ["<edition field>"],
      "repeatable": "no",
      "links_to": null,
      "transform_notes": "Text in the edition position of the entry.",
      "confidence": "Verify"
    },
    {
      "id": 8,
      "element": "Place of publication",
      "isbd_area": "Area 4 (imprint)",
      "example": "New York; Leipzig; London",
      "module": "ecatalogue",
      "tab_group": "Production / Publication",
      "emu_column": ["<publication place field>"],
      "repeatable": "maybe",
      "links_to": null,
      "transform_notes": "Token before the ':' in the imprint.",
      "confidence": "Verify"
    },
    {
      "id": 9,
      "element": "Publisher",
      "isbd_area": "Area 4 (imprint)",
      "example": "Schirmer; Breitkopf & Hartel; Peters; Hawkes",
      "module": "ecatalogue -> eparties",
      "tab_group": "Production / Publication",
      "emu_column": ["<publisher field or party link>", "role"],
      "repeatable": "maybe",
      "links_to": "eparties (org)",
      "transform_notes": "Between ':' and ','. Recurs heavily -> organisation authority record (party_type='Organisation', role='Publisher').",
      "confidence": "Verify"
    },
    {
      "id": 10,
      "element": "Publication date",
      "isbd_area": "Area 4 (imprint)",
      "example": "c1939 / c1929 / [18--] / [s.a.] / [191-?]",
      "module": "ecatalogue",
      "tab_group": "Production",
      "emu_column": ["ProDateProduced", "ProDateProducedFrom", "ProDateProducedTo"],
      "repeatable": "no",
      "links_to": null,
      "transform_notes": "Keep verbatim in ProDateProduced. Normalize: 'c1939'->from/to 1939 (circa); '[s.a.]'->null; '[18--]'->1800/1899; '[191-?]'->1910/1919.",
      "confidence": "Verify"
    },
    {
      "id": 11,
      "element": "Extent / pagination",
      "isbd_area": "Area 5 (physical)",
      "example": "11p. ; 1 conductor score (8p.) ; 2v. (165p., 179p.)",
      "module": "ecatalogue",
      "tab_group": "Description / Physical",
      "emu_column": ["PhyDescription or <extent field>"],
      "repeatable": "maybe",
      "links_to": null,
      "transform_notes": "Number & type of physical units + pagination. Watch multi-part entries ('1 set of band parts comprising ...').",
      "confidence": "Verify"
    },
    {
      "id": 12,
      "element": "Dimensions",
      "isbd_area": "Area 5 (physical)",
      "example": "30cm / 31cm / 36cm",
      "module": "ecatalogue",
      "tab_group": "Description / Dimensions",
      "emu_column": ["DimCategory_tab", "DimValue_tab", "DimUnit_tab"],
      "repeatable": "yes",
      "links_to": null,
      "transform_notes": "Height in cm. DimCategory='Height', DimUnit='cm'. May instead live in PhyDescription if dimensions table not used.",
      "confidence": "Verify"
    },
    {
      "id": 13,
      "element": "Series",
      "isbd_area": "Area 6 (series)",
      "example": "(Schirmer's library of musical classics ; vol. 1538); (Edition Peters ; no. 210)",
      "module": "ecatalogue",
      "tab_group": "Identification / Series",
      "emu_column": ["<series title field>", "<series number field>"],
      "repeatable": "yes",
      "links_to": null,
      "transform_notes": "In parentheses; split title vs '; no./vol.' number.",
      "confidence": "Verify"
    },
    {
      "id": 14,
      "element": "Plate number",
      "isbd_area": "Music-specific note",
      "example": "Pl.no.: 19107 / 34880",
      "module": "ecatalogue",
      "tab_group": "Identification / Other Numbers",
      "emu_column": ["NumOtherKind_tab", "NumOtherNumber_tab"],
      "repeatable": "yes",
      "links_to": null,
      "transform_notes": "Token after 'Pl.no.:'. NumOtherKind_tab='Plate number'.",
      "confidence": "Standard"
    },
    {
      "id": 15,
      "element": "Publisher's stock / journal number",
      "isbd_area": "Note",
      "example": "Hawkes & Sons M.B. journal ; no. 497; H. & S. 6728",
      "module": "ecatalogue",
      "tab_group": "Identification / Other Numbers",
      "emu_column": ["NumOtherKind_tab", "NumOtherNumber_tab"],
      "repeatable": "yes",
      "links_to": null,
      "transform_notes": "Distinct from plate number; NumOtherKind_tab='Publisher number'.",
      "confidence": "Standard"
    },
    {
      "id": 16,
      "element": "Contents",
      "isbd_area": "Area 7 (note)",
      "example": "Contents: Orgel-Praeludium und Fuge; Chaconne fur Violine allein",
      "module": "ecatalogue",
      "tab_group": "Notes",
      "emu_column": ["NteType_tab", "NotNotes"],
      "repeatable": "maybe",
      "links_to": null,
      "transform_notes": "Begins 'Contents:'. NteType_tab='Contents'. Each listed work may later seed related records.",
      "confidence": "Standard"
    },
    {
      "id": 17,
      "element": "Duration",
      "isbd_area": "Note",
      "example": "Duration: \"2.15 without repeats\"",
      "module": "ecatalogue",
      "tab_group": "Notes / Description",
      "emu_column": ["NteType_tab", "NotNotes"],
      "repeatable": "no",
      "links_to": null,
      "transform_notes": "NteType_tab='Duration'. Often a Grainger pencil annotation.",
      "confidence": "Verify"
    },
    {
      "id": 18,
      "element": "Inscriptions / signatures",
      "isbd_area": "Note",
      "example": "T.p. inscribed in ink: To Percy Grainger ...; Cover signed by Grainger",
      "module": "ecatalogue",
      "tab_group": "Inscriptions (or Notes)",
      "emu_column": ["<inscription text/position/method group>", "or NteType_tab='Inscription' + NotNotes"],
      "repeatable": "yes",
      "links_to": "eparties",
      "transform_notes": "Capture inscriber, position (t.p./cover), medium (ink/pencil), verbatim transcription. Grainger -> also a creators[] entry with role='Inscriber/Annotator'.",
      "confidence": "Verify"
    },
    {
      "id": 19,
      "element": "Annotations in Grainger's hand",
      "isbd_area": "Note",
      "example": "Annotated extensively in blue & red pencil by Grainger; holograph note in red ink",
      "module": "ecatalogue",
      "tab_group": "Notes",
      "emu_column": ["NteType_tab", "NotNotes"],
      "repeatable": "yes",
      "links_to": "eparties (Grainger)",
      "transform_notes": "NteType_tab='Annotation'. Keep verbatim (high research value). Link Grainger as creators[] role='Annotator'.",
      "confidence": "Standard"
    },
    {
      "id": 20,
      "element": "Manuscript / holograph statement",
      "isbd_area": "Note / object type",
      "example": "Ms. in Grainger's autograph; holograph (black ink)",
      "module": "ecatalogue",
      "tab_group": "Identification / Object type",
      "emu_column": ["<object name/category field>"],
      "repeatable": "no",
      "links_to": null,
      "transform_notes": "Drives object_type vocab: 'Printed music' vs 'Manuscript' (also 'Set of parts', 'Photoprint'). Separates printed editions from manuscript parts.",
      "confidence": "Verify"
    },
    {
      "id": 21,
      "element": "Enclosures / related parts",
      "isbd_area": "Note",
      "example": "Encl.: explanatory note in Grainger's autograph",
      "module": "ecatalogue",
      "tab_group": "Notes / Relationships",
      "emu_column": ["NteType_tab + NotNotes", "or child record + relationship link"],
      "repeatable": "maybe",
      "links_to": "ecatalogue",
