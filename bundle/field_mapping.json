      "isbd_area": "Note",
      "example": "(condition statements, mostly mss/recordings)",
      "module": "ecatalogue",
      "tab_group": "Condition (or Notes)",
      "emu_column": ["<condition field>", "or NteType_tab='Condition' + NotNotes"],
